# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="http://localhost:3000"

# Database Connections
MONGODB_URL="mongodb://root:example@mongodb:27017/"
POSTGRES_URL="postgresql+asyncpg://postgres:postgres@postgres:5432/intellishield"
REDIS_URL="redis://redis:6379/0"

# JWT Secret
JWT_SECRET="your_strong_jwt_secret_key"
JWT_ALGORITHM="HS256"

# Third-Party APIs (Placeholders)
GOOGLE_APPLICATION_CREDENTIALS="/app/google_credentials.json"
MOCK_NSDL_API_KEY="mock_pan_key"
MOCK_UIDAI_API_KEY="mock_aadhaar_key"
MOCK_VAHAN_API_KEY="mock_vahan_key"
MOCK_SARATHI_API_KEY="mock_sarathi_key"
MOCK_BANK_API_KEY="mock_bank_key"
